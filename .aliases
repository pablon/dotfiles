#===============================================================
# Navigation
#===============================================================

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."

#===============================================================
# brew
#===============================================================

if command -v brew &>/dev/null; then
  alias brew_prune="brew cleanup --prune=all -v"
  alias brew_update_all="brew update && brew upgrade && brew cleanup --prune=all -v"
fi

#===============================================================
# OS metrics
#===============================================================

alias htop='sudo htop'
if [[ "$(uname)" == "Darwin" ]]; then
  command -v powermetrics &>/dev/null && alias tempcheck="sudo powermetrics --samplers smc | grep -i 'CPU die temperature'"
  command -v osx-cpu-temp &>/dev/null && alias tempwatch="watch -d 'osx-cpu-temp -cgCf'"
fi

#===============================================================
# Utilities
#===============================================================

alias cdate='echo -n "$(date +%F\ %T\ %Z)" | $_clipboardApp'     # full-date local TZ
alias cdateu='echo -n "$(date -u +%F\ %T\ %Z)" | $_clipboardApp' # full-date UTC
alias curl="curl --progress-bar --connect-timeout 3 -m 3 -s -H 'User-Agent: Mozilla/5 Gecko'"
command -v colordiff &>/dev/null && alias diff='colordiff'
alias egrep="egrep --color=auto"
alias grep="grep --color=auto"
alias history='history -i'
if command -v eza &>/dev/null; then
  EZA_OPTS="--group-directories-first --icons=always --git-ignore -F always -o --no-user --git --color-scale all --color-scale-mode fixed"
  alias ll="eza ${EZA_OPTS} -al -s type"
  alias lld="eza ${EZA_OPTS} -al -D"
  alias llt="eza ${EZA_OPTS} -alT -s type"
  alias ls="eza ${EZA_OPTS} -a -s type"
else
  alias ll="ls -Gahop"
  alias lld="ls -lad"
  alias llt="tree --gitignore"
  alias ls="ls -GFa"
fi
alias l="ls"
alias monitor="tail -f /var/log/*.log"
command -v socat &>/dev/null && alias monsocat="watch -d \"ps ax | grep socat | egrep -v 'grep|netstat' ; netstat -tn | grep '127.0.0.1.443'\""
# (type python3 &>/dev/null) && alias python="$(which python3)"
command -v gsed &>/dev/null && alias sed='gsed'
alias stat='stat -x'
alias tm='tmux'
alias tma='tmux-attach' # see .functions
alias tmc='tmux-clone'  # see .functions
alias tmk='tmux-kill'   # see .functions
alias tmn='tmux-new'    # see .functions
alias tmls='tmux ls'
alias v.='nvim .'
alias v='nvim'
alias vi='nvim'
alias wget="wget -U 'User-Agent: Mozilla/5 Gecko' -ct 3 -T 3 --show-progress --progress=bar --no-cache"
command -v yamllint &>/dev/null && alias yamllint="yamllint -d '{extends: relaxed, rules: {line-length: {max: 280}}}'"
if command -v zoxide &>/dev/null; then
  alias cd="z"
  alias cdi="zi"
fi
command -v nc &>/dev/null && alias nc="nc -vvz -w 3"

#===============================================================
# misc
#===============================================================

# open dotfiles
alias dots='[ -d ~/dotfiles/ ] && _info "Entering dotfiles config! 🚀" && (cd ~/dotfiles/ && nvim .)'
# edit nvim configs
alias nvc="_info '📝 Opening Neovim Config' ; ([ -d "${XDG_CONFIG_HOME:-~/.config}/nvim" ] && cd "${XDG_CONFIG_HOME:-~/.config}/nvim" && nvim .)"
# obsidian new_from_template
alias on="_info '💎 Creating new Obsidian note' ; ( cd "${OBSIDIAN_VAULT_DIR:-~/obsidian-vault}/" && nvim -c 'Obsidian new_from_template' )"
# obsidian open
alias oo="_info '📝 Opening Obsidian' ; ( cd "${OBSIDIAN_VAULT_DIR:-~/obsidian-vault}/" && nvim . )"
# obsidian search
alias os="_info '🔎 Opening Obsidian search' ; ( cd "${OBSIDIAN_VAULT_DIR:-~/obsidian-vault}/" && nvim -c 'Obsidian search' )"

alias reload="reset ; source ${HOME}/.zshrc"
command -v cmatrix &>/dev/null && alias cmatrix='cmatrix -abs'
command -v ghostty &>/dev/null && alias boo='ghostty +boo'

#===============================================================
# fzf preview/edit
#===============================================================

alias pf="fzf --preview='less {}' --bind shift-up:preview-page-up,shift-down:preview-page-down"

#===============================================================
# git
#===============================================================

alias g="git"
alias ga='git a'
alias gb='git branch'
alias gco='git checkout'
alias gd='git diff'
alias gl="git log --color --graph --pretty='%C(red)%h%C(reset) -%C(auto)%d%C(reset) %s %C(green)(%ai) %C(bold blue)<%an>%C(reset)' -10"
alias gll="git log --pretty=format:'%C(red)%h%C(reset) %C(auto)%d%C(reset) %s %Cgreen(%ai) %C(bold blue)<%an>%C(reset)' --graph --stat"
alias gp='git pull'
alias gs='git status'
alias gsp='git status --porcelain'
alias gss='git status -s'
alias gu='git unstage'
alias lp="git lp"
alias st="git st"
command -v gh &>/dev/null && alias gh-create='gh repo create --private --source=. --remote=origin && git push -u --all && gh browse'
# git tuis
if command -v lazygit &>/dev/null; then
  alias gt="lazygit log -ucd ~/.config/lazygit"
elif command -v gitui &>/dev/null; then
  alias gt="gitui"
fi
# delta -- https://github.com/dandavison/delta
if command -v delta &>/dev/null; then
  alias delta="delta -n"
fi
# worktrunk -- https://github.com/max-sixty/worktrunk
# at this point (after init) wt is a shell function from ~/.zshrc_base
if (( ${+functions[wt]} )); then
  wta() {
    [[ "${1}" ]] && wt switch --create "${1}"
  }
  wtr() {
    [[ "${1}" ]] && wt remove "${1}"
  }
  alias wtl="wt list"
else
  wta() {
    [[ "${1}" ]] && git worktree add -b "${1}"
  }
  wtr() {
    [[ "${1}" ]] && git worktree remove "${1}"
  }
  alias wtl="git worktree list"
fi

#===============================================================
# docker
#===============================================================

if command -v docker &>/dev/null; then
  alias alpine='docker run --rm -it -w /mnt -v "${PWD}":/mnt:rw alpine:latest ash'
  alias d="docker"
  alias db='docker buildx build --no-cache'
  alias dc='docker compose'
  alias de='docker exec -ti'
  alias di='docker images'
  alias dils="docker image ls --format 'table {{.Repository}}\t{{.Tag}}\t{{.ID}}\t{{.Size}}'"
  alias dirm='docker image rm'
  alias dps='watch -d -n 0.5 "docker ps -a"'
  alias dr='docker run -ti --rm'
  alias dsta='docker stop $(docker ps -q)'
  alias dvprune='docker volume prune'
fi
command -v slim &>/dev/null && alias slim='slim build --http-probe-off --continue-after 1 --include-cert-all --include-cert-dirs --include-cert-pk-all --include-cert-pk-dirs --include-shell'

#===============================================================
# ACT - check ~/.actrc
#===============================================================

if command -v act &>/dev/null && command -v gh &>/dev/null; then
  alias act='act --rm -b --use-new-action-cache --detect-event -s GITHUB_TOKEN="$(gh auth token)"'
fi

#===============================================================
# kubernetes
#===============================================================

if command -v kubectl &>/dev/null; then
  if command -v kubecolor &>/dev/null; then
    alias k='kubecolor'
    alias kubectl='kubecolor'
  else
    alias k='kubectl'
  fi

  # check if it works
  command -v complete &>/dev/null && complete -o default -F __start_kubectl k

  alias kcp='kubectl cp'
  alias kdel='kubectl delete'
  alias keti='kubectl exec -t -i'
  alias kga='kubectl get all'
  alias kgaa='kubectl get all -A'
  alias kgd='kubectl get deploy'
  alias kge="kubectl get event --no-headers=true --sort-by='.lastTimestamp' -w"
  alias kgea="kubectl get event --no-headers=true -Aw"
  alias kgee='kubectl events --no-headers=true --types=Warning -w'
  alias kgn='kubectl get node --sort-by=".metadata.creationTimestamp"'
  alias kgnl='kubectl get node --sort-by=".metadata.creationTimestamp" --show-labels'
  alias kgns='kubectl get namespace'
  alias kgnsl='kubectl get namespace --show-labels'
  alias kgp='kubectl get pods --sort-by=".metadata.creationTimestamp"'
  alias kgpf='kubectl get pod --field-selector="status.phase!=Succeeded,status.phase!=Running"'
  alias kgpw='kgp --watch'
  alias kgs='kubectl get svc'
  alias klog='kubectl logs'
  alias kpf='kubectl port-forward'
  alias krh='kubectl rollout history'
  alias krs='kubectl rollout status'
  alias krsd='kubectl rollout status deployment'
  alias krsss='kubectl rollout status statefulset'
  alias kru='kubectl rollout undo'
  alias ksd='kubectl scale deployment'
  alias ktn='kubectl top node --use-protocol-buffers=true'
  alias ktnc='kubectl top node --show-capacity=true --use-protocol-buffers=true'
  alias get-taints='kubectl get node -o name | while read node ; do echo -en "$(basename ${node})\t" ; kubectl describe ${node} | grep Taint | column -tx ; done'
  alias get-all-certs='kubectl get secrets --field-selector type=kubernetes.io/tls'
  # krew stuff
  command -v kubeconform &>/dev/null && alias kubeconform='kubeconform -output pretty -summary -strict -verbose'
  # custom pods
  alias pod_alpine="kubectl run -it --rm alpine --image alpine:latest --restart=Never -- ash"
  alias pod_debian="kubectl run -it --rm debian --image debian:latest --restart=Never -- bash"
  alias pod_nats="kubectl run -it --rm nats-box --image=natsio/nats-box --restart=Never -- ash"
  alias pod_ubuntu="kubectl run -it --rm ubuntu --image ubuntu:latest --restart=Never -- bash"
fi
# kubie
if command -v kubie &>/dev/null; then
  alias kc='kubie ctx' # context selector
  alias kn='kubie ns'  # namespace selector
fi
# stern
if command -v stern &>/dev/null; then
  alias stern="stern --only-log-lines -td -H '(?i)debug|info|warn[i][n][g]|auth|fail[e][d]|error|critical|unknown|unhealthy'"
fi
# helm
if command -v helm-docs &>/dev/null; then
  alias helm-docs='helm-docs -b plastic -u'
fi

