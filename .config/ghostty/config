# common
background-blur                  = 20
background-opacity               = 0.95
copy-on-select                   = true
font-family                      = "JetBrainsMono"
font-size                        = 13
mouse-hide-while-typing          = true
selection-background             = d79921
selection-foreground             = 2e2e2e
shell-integration                = zsh
split-divider-color              = 3c425f
tab-inherit-working-directory    = true
theme                            = TokyoNight
window-decoration                = auto
window-inherit-working-directory = true
working-directory                = ~/projects
# keybindings
keybind                          = global:super+escape=toggle_quick_terminal
keybind                          = super+-=decrease_font_size:2
keybind                          = super+bracket_right=increase_font_size:1
keybind                          = super+l=clear_screen
keybind                          = super+w=close_tab:this
