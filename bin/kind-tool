#!/usr/bin/env bash
# shellcheck disable=SC2155,SC2016,SC2086
################################################################################
# Description: kind wrapper tool for local kuberetes clusters management
#
# Usage: kind-tool [-h] [-d|-k|-n]
#   -d  delete an existing cluster
#   -h  this help
#   -k  get kubeconfig for cluster
#   -n  create a cluster (dry-run)
#
# Dependencies: kind, docker/podman, kubectl, fzf, curl, jq
################################################################################

# preferred location to store kubeconfig files
# each cluster uses a separate kubeconfig file to make it easier to manage
KUBECONFIG_DIR="${HOME}/.kube/configs"

CYAN="\033[1;96m"
GREEN="\033[1;92m"
MAGENTA="\033[1;95m"
RED="\033[1;31m"
YELLOW="\033[1;93m"
NC="\033[0m"

divider() {
  local COLUMNS=80
  echo -e "${CYAN}$(eval "printf '─%.0s' {1..$COLUMNS}")${NC}"
}

show_help() {
  cat <<HELP
$(basename -- $0): kind wrapper tool for local kuberetes clusters management

Usage: kind-tool [-d] [-k] [-n]
  -d  delete an existing cluster
  -h  this help
  -k  get kubeconfig for cluster
  -n  create a cluster (dry-run)

HELP
  exit 0
}

# Required dependencies
deps=(curl fzf jq kind kubectl)
deps_missing=()
for dep in "${deps[@]}"; do
  if (! command -v "${dep}" &>/dev/null); then
    deps_missing+=("$dep")
  fi
  unset dep
done
if [ "${#deps_missing[@]}" -gt "0" ]; then
  echo -e "${YELLOW}  Found [${#deps_missing[@]}] missing dependencies, please install: ${MAGENTA}${deps_missing[*]}${NC}\n"
  exit 1
fi

gather_info() {
  divider
  get_cluster_name() {
    read -rp " 󱃾 Enter new cluster name: " KIND_CLUSTER_NAME
    while [ -z "${KIND_CLUSTER_NAME}" ]; do get_cluster_name; done
    export KIND_CLUSTER_NAME="${KIND_CLUSTER_NAME}"
  }
  get_node_tags() {
    local MAX_RESULTS=10
    export KIND_NODE_TAG="$(curl -fsSL --max-time 20 \
      "https://hub.docker.com/v2/repositories/kindest/node/tags?page_size=10&ordering=last_updated" |
      jq -r '.results[].name | select(test("^v?[0-9]+\\.[0-9]+\\.[0-9]+$"))' |
      head -n $MAX_RESULTS | sort -nr | fzf --layout reverse --border --height 40% --ghost="Select kubernetes version for cluster ${KIND_CLUSTER_NAME}" --info-command='printf "\x1b[33;1m$FZF_POS\x1b[m/$FZF_INFO 󱃾 "')"

    [ -z "${KIND_NODE_TAG}" ] && exit 0
    export KIND_NODE_VERSION="kindest/node:${KIND_NODE_TAG}"
  }
  get_cluster_nodes() {
    read -rp " 󰢒 Enter number of nodes (1-3), Hit enter for default [1]: " KIND_CLUSTER_NODES
    [[ ! ${KIND_CLUSTER_NODES} ]] && KIND_CLUSTER_NODES="1"
    if [ "${KIND_CLUSTER_NODES}" -ne "${KIND_CLUSTER_NODES}" ] || [ "${KIND_CLUSTER_NODES}" -eq "0" ] || [ "${KIND_CLUSTER_NODES}" -gt "3" ]; then
      echo "// maximum number of nodes is 3, please try again"
      get_cluster_nodes
    fi
    export KIND_CLUSTER_NODES="${KIND_CLUSTER_NODES}"
    if [ "${KIND_CLUSTER_NODES}" -gt "1" ]; then
      export KIND_WORKER_NODES="$((KIND_CLUSTER_NODES - 1))"
    fi
  }
  get_cluster_name
  get_node_tags
  get_cluster_nodes
}

create_cluster() {
  gather_info
  divider
  [ -d "${KUBECONFIG_DIR}" ] && mkdir -p "${KUBECONFIG_DIR}"
  local KIND_KUBECONFIG="${KUBECONFIG_DIR}/kind-${KIND_CLUSTER_NAME}.yaml"
  local KIND_CONFIG="$(mktemp -t "kind-config-${KIND_CLUSTER_NAME}").yaml"

  echo -e " ${CYAN}New cluster: ${GREEN}${KIND_CLUSTER_NAME}${NC}
     ${CYAN}Version:${NC} ${KIND_NODE_VERSION#*v}
       ${CYAN}Nodes:${NC} ${KIND_CLUSTER_NODES}
  ${CYAN}KUBECONFIG:${NC} ${KIND_KUBECONFIG}"

  if [ "${MODE}" != "dryrun" ]; then
    echo
    read -rp "  Proceed with cluster creation? [Y/n]: " START
    case "${START}" in
    N | n)
      echo
      exit 0
      ;;
    *)
      true
      ;;
    esac
  fi

  echo
  echo -e "${GREEN} 󱌣 Adding control-plane to kind-config..${NC}"
  cat <<EOF >"${KIND_CONFIG}"
apiVersion: kind.x-k8s.io/v1alpha4
kind: Cluster
name: ${KIND_CLUSTER_NAME}
nodes:
  # control-plane
  - role: control-plane
    kubeadmConfigPatches:
      - |
        kind: InitConfiguration
        nodeRegistration:
          kubeletExtraArgs:
            node-labels: "ingress-ready=true"
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
        protocol: TCP
      - containerPort: 443
        hostPort: 443
        protocol: TCP
EOF

  if [ "${KIND_WORKER_NODES}" ]; then
    for i in $(seq 1 ${KIND_WORKER_NODES}); do
      echo -e "${GREEN} 󱌣 Adding worker #${i} to kind-config..${NC}"
      echo -e "  # worker #${i}\n  - role: worker" >>"${KIND_CONFIG}"
    done
  fi

  CREATE_COMMAND="kind create cluster --name ${KIND_CLUSTER_NAME} --image ${KIND_NODE_VERSION} --kubeconfig ${KIND_KUBECONFIG} --config ${KIND_CONFIG}"

  if [ "${MODE}" == "dryrun" ]; then
    echo
    echo -e "${RED} 󰡾 DRY-RUN -- kind-config:\n${YELLOW}$(cat "${KIND_CONFIG}")${NC}"
    echo
    echo -e "${RED} 󰡾 DRY-RUN -- create cluster command:\n${GREEN}${CREATE_COMMAND}${NC}"
  else
    echo
    eval "${CREATE_COMMAND}"
    eval "kubectl cluster-info --context "kind-${KIND_CLUSTER_NAME}" --kubeconfig "${KIND_KUBECONFIG}""
  fi

  # cleanup
  rm -f "${KIND_CONFIG}"

  # if [ "${KIND_WORKER_NODES}" ]; then
  # install additional tools
  install_nginx_ingress
  install_caretta
  # fi
  show_cluster_objects
}

install_nginx_ingress() {
  if [ "${MODE}" != "dryrun" ]; then
    divider
    export KUBECONFIG="${KIND_KUBECONFIG}"
    local NGINX_INGRESS_MANIFEST="https://raw.githubusercontent.com/kubernetes/ingress-nginx/main/deploy/static/provider/kind/deploy.yaml"
    echo -e "${GREEN}  Installing ingress-nginx controller:${NC}"
    kubectl apply -f "${NGINX_INGRESS_MANIFEST}"
    echo -e "${GREEN} 󰔟 Waiting for pods to be ready..${NC}"
    sleep 2
    kubectl wait \
      --namespace ingress-nginx \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/component=controller \
      --timeout=120s
    sleep 2
    kubectl wait \
      --namespace ingress-nginx \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/component=admission-webhook \
      --timeout=120s
  fi
}

install_caretta() {
  if [ "${MODE}" != "dryrun" ]; then
    HELM_REPO="caretta"
    HELM_REPO_URI="https://helm.groundcover.com/"
    divider
    export KUBECONFIG="${KIND_KUBECONFIG}"
    echo -e "${GREEN}  Installing caretta, a service dependency map tool${NC}"
    (helm repo list | grep "^${HELM_REPO}" &>/dev/null) || helm repo add ${HELM_REPO_URI} &>/dev/null
    helm repo up ${HELM_REPO} &>/dev/null
    helm upgrade --install caretta \
      --namespace caretta --create-namespace \
      --set resources.limits.cpu=350m \
      --set resources.limits.memory=650Mi \
      --set grafana.grafana\.ini.adminUser=admin \
      --set grafana.grafana\.ini.adminPassword=admin \
      groundcover/caretta
    echo -e "${GREEN} 󰔟 Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace caretta \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/instance=caretta \
      --timeout=120s
  fi
}

show_cluster_objects() {
  if [ "${MODE}" != "dryrun" ]; then
    echo
    divider
    export KUBECONFIG="${KIND_KUBECONFIG}"
    echo -e "${GREEN} 󰍉 Cluster ${KIND_CLUSTER_NAME} pods:${NC}"
    kubectl get pods -A
    echo
  fi
}

get_kubeconfig() {
  if [ ! -z "$(kind get clusters)" ]; then
    export THIS_CLUSTER="$(kind get clusters 2>/dev/null | fzf --layout reverse --border --height 25% --prompt='󱃾 ' --ghost="select cluster")"
    [ -z "${THIS_CLUSTER}" ] && exit 0
    if [ "${MODE}" == "kubeconfig" ]; then
      echo -e "${YELLOW} 󰌾 Getting KUBECONFIG for cluster [${THIS_CLUSTER}]${NC}"
    fi
    local KUBECONFIG_RAW="$(kind get kubeconfig --name ${THIS_CLUSTER})"
    local CLUSTER_AUTHORITY_DATA="$(echo "${KUBECONFIG_RAW}" | yq -r '.clusters[0].cluster."certificate-authority-data"')"
    export KUBECONFIG_YAML="$(rg -l "${CLUSTER_AUTHORITY_DATA}" "${KUBECONFIG_DIR}"/*)"
    if [ "${MODE}" == "kubeconfig" ]; then
      divider
      echo -e "${GREEN} 󰄤 KUBECONFIG location for cluster [${THIS_CLUSTER}]${NC}:\n   ${KUBECONFIG_YAML}"
      divider
      if (type bat &>/dev/null); then
        echo "${KUBECONFIG_RAW}" | cut -c1-77 | sed '/data:/ s|$|...|' | bat --style=snip -S --paging never -l yaml -
      else
        kind get kubeconfig --name ${THIS_CLUSTER} | cut -c1-77 | sed '/data:/ s|$|...|'
      fi
      divider
    fi
  else
    exit 0
  fi
}

delete_cluster() {
  get_kubeconfig # get THIS_CLUSTER and KUBECONFIG_YAML
  if [ "${MODE}" == "delete" ]; then
    if [ ! -z "$(kind get clusters)" ]; then
      echo -e "${YELLOW} 󰈸 WARNING: this action cannot be undone!!!${NC}"
      if [ "${MODE}" != "dryrun" ]; then
        read -rp " 󰈸 Proceed with cluster [${THIS_CLUSTER}] deletion? [y/N]: " DELETE
        case "${DELETE}" in
        Y | y)
          true
          ;;
        *)
          echo
          exit 0
          ;;
        esac
      fi
      kind delete clusters ${THIS_CLUSTER} &&
        echo -e "${GREEN} ✔${STRONG} Deleted cluster [${THIS_CLUSTER}]${NC}" &&
        rm -vf "${KUBECONFIG_YAML}" &&
        echo -e "${GREEN} ✔${STRONG} Deleted KUBECONFIG [${KUBECONFIG_YAML}]${NC}"
    else
      exit 0
    fi
  fi
}

################################################################################
# set execution mode

while getopts dhkn Option; do
  case "${Option}" in
  d)
    MODE=delete
    delete_cluster
    exit 0
    ;;
  h)
    show_help
    ;;
  k)
    MODE=kubeconfig
    get_kubeconfig
    exit 0
    ;;
  n)
    MODE=dryrun
    create_cluster
    exit 0
    ;;
  *)
    MODE=install
    ;;
  esac
done

################################################################################
# main

create_cluster
